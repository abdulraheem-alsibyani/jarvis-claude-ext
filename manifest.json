{
  "manifest_version": 3,
  "name": "Jarvis - Claude Context Injector",
  "version": "0.1.0",
  "description": "Injects temporal and phase context into claude.ai conversation.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],

  "web_accessible_resources": [
    {
      "resources": ["injection.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jarvis"
  }
}
